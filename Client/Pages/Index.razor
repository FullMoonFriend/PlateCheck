@page "/"
@using System.Net.Http.Json
@using System.Text.Json
@using Client.Models
@using Client.Services
@inject HttpClient Http
@inject LocalStorageService Storage

<PageTitle>PlateCheck</PageTitle>

<div class="lookup-container">
    <h1>PlateCheck</h1>
    <p class="subtitle">Take a photo, enter a license plate, or look up a VIN to get vehicle details.</p>

    <div class="input-card">

        <div class="photo-row">
            <label class="photo-label">
                <span>📷 Take or Upload Photo</span>
                <InputFile OnChange="HandlePhotoSelected" accept="image/*" capture="environment" />
            </label>
            @if (isOcrLoading)
            {
                <span class="ocr-status">Analyzing photo...</span>
            }
            else if (!string.IsNullOrEmpty(ocrStatus))
            {
                <span class="ocr-status">@ocrStatus</span>
            }
        </div>

        <div class="divider"><span>or enter plate info</span></div>

        <div class="input-row">
            <div class="field">
                <label for="plate">License Plate</label>
                <input id="plate" type="text" @bind="plateNumber" @bind:event="oninput"
                       placeholder="e.g. ABC1234" maxlength="10" />
            </div>
            <div class="field field-state">
                <label for="state">State</label>
                <select id="state" @bind="selectedState">
                    <option value="">-- Select --</option>
                    @foreach (var s in States)
                    {
                        <option value="@s.Code">@s.Name</option>
                    }
                </select>
            </div>
        </div>

        <button class="lookup-btn" @onclick="LookupPlate"
                disabled="@(isLoading || isOcrLoading || string.IsNullOrWhiteSpace(plateNumber) || string.IsNullOrWhiteSpace(selectedState))">
            @if (isLoading && lookupMode == "plate")
            {
                <span>Looking up...</span>
            }
            else
            {
                <span>Look Up Plate</span>
            }
        </button>

        <div class="divider"><span>or enter a VIN</span></div>

        <div class="input-row">
            <div class="field">
                <label for="vin">VIN (Vehicle Identification Number)</label>
                <input id="vin" type="text" @bind="vinNumber" @bind:event="oninput"
                       placeholder="e.g. 1HGCM82633A004352" maxlength="17" />
            </div>
        </div>

        <button class="lookup-btn" @onclick="DecodeVin"
                disabled="@(isLoading || isOcrLoading || string.IsNullOrWhiteSpace(vinNumber))">
            @if (isLoading && lookupMode == "vin")
            {
                <span>Looking up...</span>
            }
            else
            {
                <span>Decode VIN</span>
            }
        </button>

    </div>

    @if (errorMessage != null)
    {
        <div class="error-card">@errorMessage</div>
    }

    @if (result != null && result.Success)
    {
        <div class="result-card">
            <h2>Vehicle Information</h2>
            @if (result.DataSource == "photo")
            {
                <p class="result-source">Identified from photo</p>
            }
            else if (result.DataSource == "plate")
            {
                <p class="result-source">Looked up from license plate</p>
            }
            else if (result.DataSource == "vin")
            {
                <p class="result-source">Decoded from VIN</p>
            }
            else if (result.DataSource == "both")
            {
                <p class="result-source">Photo + VIN decode</p>
            }
            <div class="result-grid">
                <ResultRow Label="Plate"        Value="@FormatPlate(result)" />
                <ResultRow Label="Year"         Value="@(result.Year ?? result.YearRange)" />
                <ResultRow Label="Make"         Value="@result.Make" />
                <ResultRow Label="Model"        Value="@result.Model" />
                <ResultRow Label="Trim"         Value="@result.Trim" />
                <ResultRow Label="Color"        Value="@result.Color" />
                <ResultRow Label="Body Style"   Value="@(result.BodyStyle ?? result.VehicleType)" />
                <ResultRow Label="VIN"          Value="@result.Vin" />
                <ResultRow Label="Fuel Type"    Value="@result.FuelType" />
                <ResultRow Label="Engine"       Value="@FormatEngine(result)" />
                <ResultRow Label="Transmission" Value="@result.Transmission" />
                <ResultRow Label="Drive Type"   Value="@result.DriveType" />
            </div>

            @if (result.DataSource == "photo" && string.IsNullOrEmpty(result.Vin))
            {
                <div class="enrich-section">
                    <p class="enrich-prompt">Enter the VIN from the door jamb or windshield for full vehicle details.</p>
                    <div class="input-row">
                        <div class="field">
                            <input type="text" @bind="enrichVin" @bind:event="oninput"
                                   placeholder="e.g. 1HGCM82633A004352" maxlength="17" />
                        </div>
                    </div>
                    <button class="lookup-btn enrich-btn" @onclick="EnrichWithVin"
                            disabled="@(isEnriching || string.IsNullOrWhiteSpace(enrichVin))">
                        @if (isEnriching)
                        {
                            <span>Enriching...</span>
                        }
                        else
                        {
                            <span>Add VIN Details</span>
                        }
                    </button>
                </div>
            }
        </div>
    }

    @if (history.Count > 0)
    {
        <div class="history-section">
            <div class="history-header">
                <h2>Recent Lookups</h2>
                <button class="clear-btn" @onclick="ClearHistory">Clear History</button>
            </div>
            <div class="history-list">
                @foreach (var entry in history)
                {
                    <div class="history-item" @onclick="() => RestoreFromHistory(entry)">
                        <div class="history-item-main">
                            <span class="history-title">@entry.DisplayTitle</span>
                            <span class="history-time">@entry.RelativeTime</span>
                        </div>
                        <span class="history-subtitle">@entry.DisplaySubtitle</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private const string HistoryKey = "platecheck_history";
    private const int MaxHistory = 25;

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    private string plateNumber = string.Empty;
    private string selectedState = string.Empty;
    private string vinNumber = string.Empty;
    private string enrichVin = string.Empty;
    private string lookupMode = string.Empty;
    private bool isLoading;
    private bool isOcrLoading;
    private bool isEnriching;
    private string? errorMessage;
    private string? ocrStatus;
    private VehicleResult? result;
    private string? currentHistoryId;
    private List<HistoryEntry> history = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task HandlePhotoSelected(InputFileChangeEventArgs e)
    {
        isOcrLoading = true;
        ocrStatus = null;
        errorMessage = null;
        result = null;
        enrichVin = string.Empty;
        currentHistoryId = null;
        StateHasChanged();

        try
        {
            var file = e.File;

            var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var imageContent = new StreamContent(stream);
            imageContent.Headers.ContentType =
                new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);

            var response = await Http.PostAsync("api/ocr-plate", imageContent);

            if (!response.IsSuccessStatusCode)
            {
                ocrStatus = "Could not read plate from photo.";
                return;
            }

            var ocrResult = await response.Content.ReadFromJsonAsync<VehicleResult>();

            if (ocrResult == null || !ocrResult.Success)
            {
                ocrStatus = ocrResult?.ErrorMessage ?? "No plate detected. Please enter a VIN instead.";
                return;
            }

            // Populate plate/state fields from OCR
            plateNumber = ocrResult.PlateNumber;
            selectedState = ocrResult.State;

            if (!string.IsNullOrEmpty(ocrResult.Make) || !string.IsNullOrEmpty(ocrResult.Model))
            {
                result = ocrResult;
                ocrStatus = $"Plate detected: {ocrResult.PlateNumber}";
                await SaveToHistory(result);
            }
            else
            {
                result = ocrResult;
                ocrStatus = $"Plate detected: {ocrResult.PlateNumber}. Add a VIN below for full details.";
                await SaveToHistory(result);
            }
        }
        catch (Exception ex)
        {
            ocrStatus = "Photo error — please enter a VIN instead.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            isOcrLoading = false;
        }
    }

    private async Task LookupPlate()
    {
        isLoading = true;
        lookupMode = "plate";
        errorMessage = null;
        result = null;
        currentHistoryId = null;
        StateHasChanged();

        try
        {
            var resp = await Http.GetAsync(
                $"api/lookup-plate?plate={Uri.EscapeDataString(plateNumber)}&state={Uri.EscapeDataString(selectedState)}");

            if (!resp.IsSuccessStatusCode)
            {
                errorMessage = "Plate lookup failed. Please check the plate and state.";
                return;
            }

            result = await resp.Content.ReadFromJsonAsync<VehicleResult>();
            if (result != null && result.Success)
            {
                result.DataSource = "plate";
                await SaveToHistory(result);
            }
            else
            {
                errorMessage = result?.ErrorMessage ?? "No vehicle found for this plate/state combination.";
                result = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An unexpected error occurred. Please try again.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DecodeVin()
    {
        isLoading = true;
        lookupMode = "vin";
        errorMessage = null;
        result = null;
        currentHistoryId = null;
        StateHasChanged();

        try
        {
            var resp = await Http.GetAsync(
                $"api/decode-vin?vin={Uri.EscapeDataString(vinNumber)}");

            if (!resp.IsSuccessStatusCode)
            {
                errorMessage = "VIN decode failed. Please check the VIN and try again.";
                return;
            }

            result = await resp.Content.ReadFromJsonAsync<VehicleResult>();
            if (result != null)
            {
                result.DataSource = "vin";
                await SaveToHistory(result);
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An unexpected error occurred. Please try again.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task EnrichWithVin()
    {
        if (result == null) return;

        isEnriching = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var resp = await Http.GetAsync(
                $"api/decode-vin?vin={Uri.EscapeDataString(enrichVin)}");

            if (!resp.IsSuccessStatusCode)
            {
                errorMessage = "VIN decode failed. Please check the VIN and try again.";
                return;
            }

            var vinResult = await resp.Content.ReadFromJsonAsync<VehicleResult>();
            if (vinResult == null) return;

            // Merge: OCR wins for plate/state/color, NHTSA wins for everything else
            result.Vin = vinResult.Vin;
            result.Year = vinResult.Year ?? result.Year;
            result.Make = vinResult.Make ?? result.Make;
            result.Model = vinResult.Model ?? result.Model;
            result.Trim = vinResult.Trim;
            result.BodyStyle = vinResult.BodyStyle ?? result.BodyStyle;
            result.FuelType = vinResult.FuelType;
            result.EngineDisplacement = vinResult.EngineDisplacement;
            result.Cylinders = vinResult.Cylinders;
            result.Transmission = vinResult.Transmission;
            result.DriveType = vinResult.DriveType;
            result.DataSource = "both";

            await SaveToHistory(result);
        }
        catch (Exception ex)
        {
            errorMessage = "An unexpected error occurred. Please try again.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            isEnriching = false;
        }
    }

    private async Task SaveToHistory(VehicleResult r)
    {
        var entry = new HistoryEntry
        {
            Id = currentHistoryId ?? Guid.NewGuid().ToString(),
            PlateNumber = r.PlateNumber,
            State = r.State,
            Vin = r.Vin,
            Make = r.Make,
            Model = r.Model,
            Year = r.Year,
            YearRange = r.YearRange,
            Color = r.Color,
            Trim = r.Trim,
            BodyStyle = r.BodyStyle,
            VehicleType = r.VehicleType,
            FuelType = r.FuelType,
            EngineDisplacement = r.EngineDisplacement,
            Cylinders = r.Cylinders,
            Transmission = r.Transmission,
            DriveType = r.DriveType,
            DataSource = r.DataSource,
            Timestamp = DateTime.UtcNow
        };

        currentHistoryId = entry.Id;

        // Update in place if exists, otherwise insert at front
        var existing = history.FindIndex(h => h.Id == entry.Id);
        if (existing >= 0)
        {
            history[existing] = entry;
        }
        else
        {
            history.Insert(0, entry);
            if (history.Count > MaxHistory)
                history.RemoveAt(history.Count - 1);
        }

        var json = JsonSerializer.Serialize(history, JsonOptions);
        await Storage.SetAsync(HistoryKey, json);
    }

    private async Task LoadHistory()
    {
        var json = await Storage.GetAsync(HistoryKey);
        if (!string.IsNullOrEmpty(json))
        {
            history = JsonSerializer.Deserialize<List<HistoryEntry>>(json, JsonOptions) ?? new();
        }
    }

    private async Task ClearHistory()
    {
        history.Clear();
        await Storage.RemoveAsync(HistoryKey);
    }

    private void RestoreFromHistory(HistoryEntry entry)
    {
        currentHistoryId = entry.Id;
        result = new VehicleResult
        {
            PlateNumber = entry.PlateNumber,
            State = entry.State,
            Vin = entry.Vin,
            Make = entry.Make,
            Model = entry.Model,
            Year = entry.Year,
            YearRange = entry.YearRange,
            Color = entry.Color,
            Trim = entry.Trim,
            BodyStyle = entry.BodyStyle,
            VehicleType = entry.VehicleType,
            FuelType = entry.FuelType,
            EngineDisplacement = entry.EngineDisplacement,
            Cylinders = entry.Cylinders,
            Transmission = entry.Transmission,
            DriveType = entry.DriveType,
            DataSource = entry.DataSource,
            Success = true
        };
        errorMessage = null;
        ocrStatus = null;
    }

    private static string? FormatPlate(VehicleResult r)
    {
        if (string.IsNullOrEmpty(r.PlateNumber)) return null;
        return string.IsNullOrEmpty(r.State) ? r.PlateNumber : $"{r.PlateNumber} ({r.State})";
    }

    private static string? FormatEngine(VehicleResult r)
    {
        if (r.EngineDisplacement == null && r.Cylinders == null) return null;
        var parts = new List<string>();
        if (r.EngineDisplacement != null) parts.Add($"{r.EngineDisplacement}L");
        if (r.Cylinders != null) parts.Add($"{r.Cylinders}-cyl");
        return string.Join(" ", parts);
    }

    private record StateInfo(string Code, string Name);

    private static readonly StateInfo[] States = new StateInfo[]
    {
        new("AL","Alabama"), new("AK","Alaska"), new("AZ","Arizona"), new("AR","Arkansas"),
        new("CA","California"), new("CO","Colorado"), new("CT","Connecticut"), new("DE","Delaware"),
        new("FL","Florida"), new("GA","Georgia"), new("HI","Hawaii"), new("ID","Idaho"),
        new("IL","Illinois"), new("IN","Indiana"), new("IA","Iowa"), new("KS","Kansas"),
        new("KY","Kentucky"), new("LA","Louisiana"), new("ME","Maine"), new("MD","Maryland"),
        new("MA","Massachusetts"), new("MI","Michigan"), new("MN","Minnesota"), new("MS","Mississippi"),
        new("MO","Missouri"), new("MT","Montana"), new("NE","Nebraska"), new("NV","Nevada"),
        new("NH","New Hampshire"), new("NJ","New Jersey"), new("NM","New Mexico"), new("NY","New York"),
        new("NC","North Carolina"), new("ND","North Dakota"), new("OH","Ohio"), new("OK","Oklahoma"),
        new("OR","Oregon"), new("PA","Pennsylvania"), new("RI","Rhode Island"), new("SC","South Carolina"),
        new("SD","South Dakota"), new("TN","Tennessee"), new("TX","Texas"), new("UT","Utah"),
        new("VT","Vermont"), new("VA","Virginia"), new("WA","Washington"), new("WV","West Virginia"),
        new("WI","Wisconsin"), new("WY","Wyoming"), new("DC","District of Columbia")
    };
}
